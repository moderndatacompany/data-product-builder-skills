# ==============================================================================
# Snowflake Environment Variables for Gensler Qualtrics Vulcan Data Product
# ==============================================================================
# 
# Instructions:
# 1. Copy this file to .env: cp env.snowflake.template .env
# 2. Fill in your actual values
# 3. Load variables: source .env (or use direnv, dotenv, etc.)
# 4. NEVER commit .env to version control (add to .gitignore)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# Snowflake Connection
# ------------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=EQZOTUQ-JCA67320
SNOWFLAKE_USER=SHREYA
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=VULCAN
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ------------------------------------------------------------------------------
# Snowflake Authentication (Key-Pair)
# ------------------------------------------------------------------------------
# Path to your encrypted private key file (PKCS#8 format)
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/your/snowflake_key.p8

# Passphrase for the encrypted private key
# For development/testing with the existing key from generate_and_load_qualtrics_data.py:
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=shreya
# For production, use a strong passphrase:
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_secure_passphrase_here

# Alternative: Inline private key (not recommended - use path above instead)
# SNOWFLAKE_PRIVATE_KEY="-----BEGIN ENCRYPTED PRIVATE KEY-----\nMIIF...\n-----END ENCRYPTED PRIVATE KEY-----"

# ------------------------------------------------------------------------------
# Vulcan Configuration
# ------------------------------------------------------------------------------
VULCAN_ENV=development
VULCAN_CONFIG=config.yaml

# ------------------------------------------------------------------------------
# Vulcan Analytics (Optional - CloudEvents)
# ------------------------------------------------------------------------------
VULCAN_ANALYTICS_ENABLED=false
# VULCAN_ANALYTICS_BASE_URL=https://your-dataos-instance.dataos.app/cloudevents/api/v1
# VULCAN_ANALYTICS_API_KEY=your_api_key_here
# VULCAN_ANALYTICS_SOURCE_NAME=gensler_qualtrics_snowflake

# ------------------------------------------------------------------------------
# OpenLineage (Optional - Data Lineage Tracking)
# ------------------------------------------------------------------------------
OPENLINEAGE_ENABLED=false
# OPENLINEAGE_URL=http://127.0.0.1:8000
# OPENLINEAGE_API_KEY=your_openlineage_api_key

# ------------------------------------------------------------------------------
# Heimdall Authentication (Optional - DataOS Enterprise)
# ------------------------------------------------------------------------------
# HEIMDALL_ENABLED=false
# HEIMDALL_BASE_URL=https://your-dataos-instance.dataos.app/heimdall
# HEIMDALL_TIMEOUT=10

# ------------------------------------------------------------------------------
# Notifications (Optional)
# ------------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM_EMAIL=vulcan@company.com
# SMTP_TO_EMAILS=data-team@company.com

# ------------------------------------------------------------------------------
# Data Quality Thresholds (Optional - Used in Models/Checks)
# ------------------------------------------------------------------------------
MIN_RESPONSE_COUNT=30
MIN_SURVEY_COUNT=10
MAX_RESPONSE_AGE_DAYS=365
DATA_RETENTION_DAYS=365

# ------------------------------------------------------------------------------
# Schema Configuration (Optional - Override Defaults)
# ------------------------------------------------------------------------------
RAW_SCHEMA=QUALTRICS
BRONZE_SCHEMA=QUALTRICS_BRONZE
SILVER_SCHEMA=QUALTRICS_SILVER
GOLD_SCHEMA=QUALTRICS_GOLD
STATE_SCHEMA=VULCAN_STATE_QUALTRICS

# ------------------------------------------------------------------------------
# Development Settings
# ------------------------------------------------------------------------------
# Enable debug logging
# VULCAN_DEBUG=true
# VULCAN_LOG_LEVEL=DEBUG

# Parallel execution
# VULCAN_PARALLEL_TASKS=4

# Query timeout (seconds)
# SNOWFLAKE_QUERY_TIMEOUT=600

# ------------------------------------------------------------------------------
# Usage Examples
# ------------------------------------------------------------------------------
# 
# Load environment variables:
#   source .env
#   # or with direnv:
#   echo "dotenv" >> .envrc && direnv allow
#
# Run Vulcan commands:
#   vulcan plan --config config.yaml
#   vulcan apply --config config.yaml
#   vulcan run --config config.yaml
#   vulcan test --config config.yaml
#
# Run data loading script:
#   cd data-movement-nilus/gensler-qualtrics-api
#   python generate_and_load_qualtrics_data.py
#
# Query Snowflake:
#   snowsql -a $SNOWFLAKE_ACCOUNT -u $SNOWFLAKE_USER --authenticator=SNOWFLAKE_JWT
#
# ==============================================================================

